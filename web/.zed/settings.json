{
  "format_on_save": "on",
  "languages": {
    "TypeScript": {
      "formatter": {
        "external": {
          "command": "bunx",
          "arguments": [
            "prettier",
            "--stdin-filepath",
            "{buffer_path}"
          ]
        }
      }
    },
    "TSX": {
      "formatter": {
        "external": {
          "command": "bunx",
          "arguments": [
            "prettier",
            "--stdin-filepath",
            "{buffer_path}"
          ]
        }
      }
    },
    "JavaScript": {
      "formatter": {
        "external": {
          "command": "bunx",
          "arguments": [
            "prettier",
            "--stdin-filepath",
            "{buffer_path}"
          ]
        }
      }
    },
    "JSON": {
      "formatter": {
        "external": {
          "command": "bunx",
          "arguments": [
            "prettier",
            "--stdin-filepath",
            "{buffer_path}"
          ]
        }
      }
    },
    "Go": {
      "formatter": "language_server"
    }
  }
}
